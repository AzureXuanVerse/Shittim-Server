{
  "name": "shittim-control-center",
  "productName": "Shittim Control Center",
  "version": "1.0.1",
  "description": "Blue Archive themed control center for the Shittim-Server: configure, launch, and administer the server, accounts, inventory, mail, events and gacha.",
  "main": "main.js",
  "author": "Shittim",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.shittim.controlcenter",
    "productName": "Shittim Control Center",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Neoexm",
        "repo": "Shittim-Server"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "Sprite/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
